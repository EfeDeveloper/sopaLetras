{
  "name": "sopa-de-letras",
  "version": "2.0.0",
  "description": "Juego de sopa de letras",
  "scripts": {
    "dev": "tailwindcss -i ./src/input.css -o ./public/output.css --watch",
    "build": "tailwindcss -i ./src/input.css -o ./public/output.css --minify",
    "serve": "npx http-server . -p 3000 -o /index.html",
    "start": "npm run build && npm run serve"
  },
  "keywords": [
    "word-search",
    "sopa-letras",
    "game"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "tailwindcss": "^3.4.0",
    "autoprefixer": "^10.4.0",
    "postcss": "^8.4.0"
  }
}
