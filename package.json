{
  "name": "sopa-de-letras",
  "version": "2.0.0",
  "description": "Juego de sopa de letras",
  "scripts": {
    "dev": "concurrently \"npm run dev:css\" \"npm run dev:server\"",
    "dev:css": "tailwindcss -i ./src/input.css -o ./public/output.css --watch",
    "dev:server": "npx http-server . -p 3000 -o /index.html -c-1",
    "build": "tailwindcss -i ./src/input.css -o ./public/output.css --minify",
    "start": "npx http-server . -p 3000"
  },
  "keywords": [
    "word-search",
    "sopa-letras",
    "game"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "http-server": "^14.1.1"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.0",
    "concurrently": "^9.2.1",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0"
  }
}